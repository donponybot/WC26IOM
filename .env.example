# Copy this to .env and fill in your values

# Admin password for unlocking predictions (change this!)
REACT_APP_ADMIN_PASSWORD=wc2026admin

# Your free API key from https://www.football-data.org/client/register
REACT_APP_FD_API_KEY=your_api_key_here

# FIFA World Cup competition ID on football-data.org (confirm once WC2026 is listed)
REACT_APP_FD_COMPETITION=2000

# Cloudflare Worker proxy URL for the News tab
# Deploy wc2026-proxy/ first, then paste the worker URL here
REACT_APP_NEWS_PROXY=https://wc2026-news.YOUR_SUBDOMAIN.workers.dev
